# Generated data files (regenerated by pipeline)
data/*.jsonl
data/*.json

# ArXiv papers (downloaded via arXiv API, ~75MB)
data/arxiv_papers/

# Colab training archive (rebuilt by pack_training_data.sh)
data/colab_training_data.tar.gz

# Model checkpoints
checkpoints/

# Training results (model weights + eval JSONs per run)
# Pattern is `results/*` (not `results/`) so the directory itself isn't
# excluded — that lets `!results/*.md` actually re-include doc files.
# Per `gitignore(5)`: "It is not possible to re-include a file if a
# parent directory of that file is excluded."
results/*
!results/*.md
!results/.gitkeep

# Evaluation results (regenerated by pipeline)
eval_*.json

# Python cache
__pycache__/
*.pyc
*.pyo

# Jupyter checkpoints
.ipynb_checkpoints/
